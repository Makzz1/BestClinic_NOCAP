# ──────────────────────────────────────────────
# QueueCure — Environment Variables
# Copy this file to .env and fill in your values
# ──────────────────────────────────────────────

# MongoDB connection string (Atlas or local)
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/queuecure?retryWrites=true&w=majority

# JWT secret for authentication tokens (use a strong random string)
JWT_SECRET=your_jwt_secret_here

# Default admin account (created on first seed)
ADMIN_EMAIL=admin@queuecure.com
ADMIN_PASSWORD=admin123

# Server port
PORT=5000

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# Gmail SMTP credentials for email notifications
# To generate an App Password: Google Account → Security → 2-Step Verification → App Passwords
MAIL_USER=your_email@gmail.com
MAIL_PASS=your_app_password_here
